NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://cloth:cloth_password@localhost:5432/cloth_agent
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters

WECHAT_APP_ID=
WECHAT_APP_SECRET=
ALLOW_DEV_LOGIN=true

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
# 对外签名 URL 用的公网端点（手机/试衣厂商需访问）。云服务器常无法访问自身公网IP，
# 故内部操作用 MINIO_ENDPOINT=127.0.0.1，对外签名用 MINIO_PUBLIC_ENDPOINT=公网IP/域名。
# 留空则回退用 MINIO_ENDPOINT。
MINIO_PUBLIC_ENDPOINT=
MINIO_PUBLIC_PORT=
MINIO_PUBLIC_USE_SSL=
MINIO_ACCESS_KEY=cloth_minio
MINIO_SECRET_KEY=cloth_minio_password
MINIO_BUCKET=cloth-agent

TRYON_PROVIDER=aliyun
# 阿里云百炼 AI 试衣（中国内地北京地域）
DASHSCOPE_API_KEY=
# aitryon：0.20 元/张；aitryon-plus：0.50 元/张，纹理与 Logo 还原更好
ALIYUN_TRYON_MODEL=aitryon
# 使用 fal.ai 的 FASHN 试穿模型时设 TRYON_PROVIDER=fal 并填 FAL_KEY
FAL_KEY=
FAL_MODEL_ID=fal-ai/fashn/tryon/v1.5
AI_CREATE_URL=
AI_STATUS_URL=
AI_API_KEY=
# 喂给试衣厂商的人像/服装图签名有效期（秒），须大于轮询总耗时，默认 6 小时
AI_ASSET_TTL_SECONDS=21600
# 轮询厂商任务状态的间隔与最大次数（默认 3000ms × 60 = 180s 超时）
AI_POLL_INTERVAL_MS=3000
AI_POLL_MAX_ATTEMPTS=60
ANTHROPIC_API_KEY=
