NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://cloth:cloth_password@localhost:5432/cloth_agent
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-random-characters

WECHAT_APP_ID=
WECHAT_APP_SECRET=
ALLOW_DEV_LOGIN=true

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=cloth_minio
MINIO_SECRET_KEY=cloth_minio_password
MINIO_BUCKET=cloth-agent

TRYON_PROVIDER=mock
# 使用 fal.ai 的 FASHN 试穿模型时设 TRYON_PROVIDER=fal 并填 FAL_KEY
FAL_KEY=
FAL_MODEL_ID=fal-ai/fashn/tryon/v1.5
AI_CREATE_URL=
AI_STATUS_URL=
AI_API_KEY=
# 喂给试衣厂商的人像/服装图签名有效期（秒），须大于轮询总耗时，默认 6 小时
AI_ASSET_TTL_SECONDS=21600
# 轮询厂商任务状态的间隔与最大次数（默认 3000ms × 60 = 180s 超时）
AI_POLL_INTERVAL_MS=3000
AI_POLL_MAX_ATTEMPTS=60
ANTHROPIC_API_KEY=
